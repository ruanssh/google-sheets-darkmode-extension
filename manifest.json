{
  "manifest_version": 3,
  "name": "Google Sheets Dark Mode",
  "version": "1.1.0",
  "description": "Aplica modo escuro automaticamente no Google Sheets com botao para ativar/desativar.",
  "permissions": ["storage"],
  "action": {
    "default_title": "Sheets Dark Mode",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["https://docs.google.com/spreadsheets/*"],
      "css": ["styles.css"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ]
}
